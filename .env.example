# Ambiente: dev | staging | prod
ENV=dev

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Postgres (na VPS via Easypanel). Solicite credenciais ao infra owner.
DATABASE_URL=postgresql+asyncpg://freela:CHANGE_ME@93.127.211.7:5435/freela_food

# Redis (na VPS via Easypanel). Solicite credenciais ao infra owner.
REDIS_URL=redis://:CHANGE_ME@93.127.211.7:6380/0

# JWT — gere um segredo forte (>= 32 bytes). Ex: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Bcrypt cost factor (>= 12 em produção)
BCRYPT_ROUNDS=12

# CORS — lista separada por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry (opcional — deixe vazio em dev)
SENTRY_DSN=

# Chave pra criptografar CPF/CNPJ via pgcrypto (>= 32 chars, mantenha em segredo)
DB_ENCRYPTION_KEY=CHANGE_ME_RANDOM_64_CHARS

# MinIO / S3 — uploads de avatar e mídia
S3_ENDPOINT_URL=http://93.127.211.7:9000
S3_REGION=us-east-1
S3_BUCKET=freela-food-uploads
S3_PUBLIC_BASE_URL=http://93.127.211.7:9000/freela-food-uploads
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# Janela de soft-delete antes do hard purge
DELETE_GRACE_PERIOD_DAYS=30

